{
  "name": "@magefayre/druidcraft",
  "description": "Never struggle with choosing a Wild Shape again",
  "version": "1.13.1",
  "author": "Magefayre",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/magefayre/druidcraft.git"
  },
  "homepage": "https://github.com/magefayre/druidcraft#readme",
  "bugs": {
    "url": "https://github.com/magefayre/druidcraft/issues"
  },
  "packageManager": "yarn@4.17.1",
  "files": [
    "public",
    "src",
    ".env",
    "eslint.config.mjs",
    "jsconfig.json",
    "next-sitemap.js",
    "next.config.js",
    "postcss.config.js",
    "site.config.js",
    "svgr.config.js"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf {.next,public/{robots.txt,sitemap*.xml}}",
    "prestart": "yarn clean || exit 0",
    "start": "next dev --webpack",
    "build": "next build --webpack",
    "postbuild": "next-sitemap",
    "serve": "next start",
    "sync-with-5etools": "tsx scripts/sync-with-5etools --output src/data",
    "postsync-with-5etools": "yarn format:js src/data",
    "pretest": "next typegen && tsc --noEmit",
    "test": "yarn lint && vitest run",
    "lint": "concurrently 'yarn:lint:*'",
    "lint:js": "eslint --cache .",
    "lint:css": "stylelint --cache --ignore-path .gitignore '**/*.?(s)css'",
    "format": "concurrently 'yarn:format:*'",
    "format:js": "yarn lint:js --fix",
    "format:css": "yarn lint:css --fix"
  },
  "dependencies": {
    "@newhighsco/chipset": "7.4.0",
    "@newhighsco/next-plugin-svgr": "3.0.173",
    "@newhighsco/press-start": "2.9.0",
    "@newhighsco/ts-config": "1.2.2",
    "@sindresorhus/slugify": "3.0.0",
    "@sindresorhus/transliterate": "2.3.1",
    "@types/react": "19.2.17",
    "next": "16.2.10",
    "next-compose-plugins": "2.2.1",
    "next-sitemap": "4.2.3",
    "postcss": "8.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sass": "1.101.0",
    "usehooks-ts": "3.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@newhighsco/browserslist-config": "3.0.1",
    "@newhighsco/commitlint-config": "1.3.4",
    "@newhighsco/editor-config": "1.2.0",
    "@newhighsco/eslint-config": "7.1.24",
    "@newhighsco/lint-staged-config": "1.1.1",
    "@newhighsco/postcss-config": "4.0.66",
    "@newhighsco/prettier-config": "2.3.12",
    "@newhighsco/release-config": "1.5.5",
    "@newhighsco/stylelint-config": "4.0.53",
    "@newhighsco/svgr-config": "1.0.0",
    "@newhighsco/ts-config": "1.2.2",
    "@newhighsco/yarn-plugin-preset": "1.1.4",
    "@types/react": "19.2.17",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "plur": "6.0.0",
    "prettier": "3.9.5",
    "semantic-release": "25.0.8",
    "stylelint": "17.14.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "yargs": "18.0.0"
  },
  "browserslist": [
    "extends @newhighsco/browserslist-config"
  ],
  "commitlint": {
    "extends": [
      "@newhighsco"
    ]
  },
  "prettier": "@newhighsco/prettier-config",
  "release": {
    "extends": "@newhighsco/release-config"
  },
  "stylelint": {
    "extends": [
      "@newhighsco/stylelint-config"
    ]
  }
}
