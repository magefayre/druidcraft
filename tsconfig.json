{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@newhighsco/ts-config/next",
  "compilerOptions": {
    "paths": {
      "~components/*": ["./src/components/*"],
      "~constants": ["./src/constants"],
      "~config": ["./site.config"],
      "~data/*": ["./src/data/*"],
      "~hooks/*": ["./src/hooks/*"],
      "~images/*": ["./src/images/*"],
      "~layouts/*": ["./src/layouts/*"],
      "~styles/*": ["./src/styles/_*", "./src/styles/*"],
      "~theme": ["./src/theme"],
      "~types": ["./src/types"],
      "~utils": ["./src/utils"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["**/*"]
}
