{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>magefayre/.github:renovate-config"],
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "5etools-mirror-3/5etools-2014-src",
      "description": "Update 5etools version used by `sync-with-5etools`",
      "managerFilePatterns": ["scripts/constants.ts"],
      "matchStrings": ["(?<currentValue>v\\d+\\.\\d+\\.\\d+)"]
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["5etools-mirror-3/5etools-2014-src"],
      "semanticCommitType": "fix"
    }
  ]
}
